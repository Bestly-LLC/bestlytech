# Copy this to scripts/.env on the Raspberry Pi and fill in real values.
# The .env file is gitignored — never commit real keys.

# Pi-hole base URL (from the Pi's perspective — localhost is fine if script runs on the Pi)
PIHOLE_URL=http://localhost

# Pi-hole API token (only needed if you have a web password set on Pi-hole)
# Find it at: Pi-hole Admin → Settings → API / Web interface → Show API token
# PIHOLE_TOKEN=

# Supabase project URL (same as VITE_SUPABASE_URL in the frontend .env)
SUPABASE_URL=https://keowunrxpxlbgebujbao.supabase.co

# Supabase SERVICE ROLE key — NOT the anon key.
# Find it at: Supabase Dashboard → Project Settings → API → service_role (secret)
# This key bypasses RLS so the Pi can INSERT into home_hub_pihole_stats.
SUPABASE_SERVICE_KEY=

# Copy this to scripts/.env on the Raspberry Pi and fill in the values below.
# The .env file is gitignored — never commit it with real keys.

# Pi-hole base URL (from the Pi's perspective — localhost is correct when the script runs on the Pi)
PIHOLE_URL=http://localhost

# Pi-hole API token (only needed if Pi-hole has a web password set)
# Find it at: Pi-hole Admin → Settings → API / Web interface → Show API token
# PIHOLE_TOKEN=

# Supabase project URL
SUPABASE_URL=https://rcqfqhguwpmaarseifqg.supabase.co

# Supabase SERVICE ROLE key — NOT the anon key.
# Find it at: Supabase Dashboard → Project Settings → API → service_role (secret)
# This bypasses RLS so the Pi can INSERT into home_hub_pihole_stats.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJjcWZxaGd1d3BtYWFyc2VpZnFnIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTM1NzU5NSwiZXhwIjoyMDkwOTMzNTk1fQ.1PPPXwb9IQBiRHGaK_1JinrPbVeiNjiwai-kcpEE2iI
